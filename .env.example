# Copy to .env and fill in. Both are optional — Samwise degrades gracefully
# without them (deterministic narration + on-screen text instead of voice).
#
# NEVER put real keys in this file — it is committed to git. Real keys go in
# .env (which is gitignored).

# OpenAI — used during PLANNING to rewrite narration into plain language and
# map the user profile to form fields. Results are cached into the plan, so the
# live run never waits on the network.
EXPO_PUBLIC_OPENAI_API_KEY=

# ElevenLabs — text-to-speech for narration and speech-to-text for the mic.
# Narration audio is pre-generated during PLANNING and cached for instant,
# WiFi-independent playback on stage.
EXPO_PUBLIC_ELEVENLABS_API_KEY=

# Optional overrides
EXPO_PUBLIC_OPENAI_MODEL=gpt-4o-mini
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
